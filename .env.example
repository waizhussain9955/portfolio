# =============================================
# Waiz Hussain Portfolio - Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values
# In Vercel: go to Project Settings → Environment Variables and add these

# ------ Database (NeonDB / PostgreSQL) ------
# Get from: https://neon.tech → Your Project → Connection String
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ------ AI Chatbot (Cerebras) ------
# Get from: https://cloud.cerebras.ai → API Keys
CEREBRAS_API_KEY="csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ------ JWT Authentication ------
# Generate a strong random string (min 32 chars)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
